RewriteEngine On

# If user requests a directory path without trailing slash — append it
# (Next.js uses trailingSlash:true, so /training should become /training/)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [L,R=301]

# Default index file lookup
DirectoryIndex index.html

# Cache static assets aggressively
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|woff2?|ttf|otf|eot|ico|png|jpg|jpeg|webp|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
